{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "Uma tarefa ou compromisso agendado no sistema Vall",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único da tarefa"
        },
        "title": {
          "type": "string",
          "description": "Título ou resumo da tarefa"
        },
        "description": {
          "type": "string",
          "description": "Descrição detalhada complementar"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Data de realização no formato YYYY-MM-DD"
        },
        "category": {
          "type": "string",
          "enum": ["Agendamento", "Curinga", "Disponível", "Notas"],
          "description": "Categoria da tarefa"
        },
        "priority": {
          "type": "string",
          "enum": ["Alta", "Média", "Baixa"],
          "description": "Nível de prioridade"
        },
        "status": {
          "type": "string",
          "enum": ["Pendente", "Em Progresso", "Concluída"],
          "description": "Status de execução atual"
        },
        "estimatedMinutes": {
          "type": "integer",
          "description": "Tempo estimado em minutos"
        },
        "actualMinutes": {
          "type": "integer",
          "description": "Tempo gasto ou focado em minutos"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data/hora de criação"
        },
        "userEmail": {
          "type": "string",
          "description": "E-mail do usuário dono da tarefa"
        }
      },
      "required": ["id", "title", "date", "category", "priority", "status", "userEmail"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil de inquilino de cada usuário autenticado",
      "type": "object",
      "properties": {
        "organizationId": {
          "type": "string",
          "description": "ID da organização ativa do usuário"
        },
        "email": {
          "type": "string",
          "description": "E-mail principal do usuário"
        },
        "displayName": {
          "type": "string",
          "description": "Nome de exibição do usuário"
        }
      },
      "required": ["organizationId", "email"]
    },
    "Organization": {
      "title": "Organization",
      "description": "Ativo de representação multitenancy organizacional",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nome fantasia da corporação/time"
        },
        "createdBy": {
          "type": "string",
          "description": "UID do criador administrador"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora de criação"
        }
      },
      "required": ["name", "createdBy", "createdAt"]
    },
    "Member": {
      "title": "Member",
      "description": "Perfil de membro específico de uma organização",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "UID do usuário correspondente"
        },
        "email": {
          "type": "string",
          "description": "E-mail do membro"
        },
        "displayName": {
          "type": "string",
          "description": "Nome de exibição do membro"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "viewer"],
          "description": "Função em controle de acessos da hierarquia da empresa"
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora de ingresso"
        }
      },
      "required": ["uid", "email", "role", "joinedAt"]
    },
    "Invite": {
      "title": "Invite",
      "description": "Metadados de envio de convites de equipes",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID único do convite"
        },
        "email": {
          "type": "string",
          "description": "E-mail do candidato convidado"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "viewer"],
          "description": "Role que será herdada ao aceitar"
        },
        "organizationId": {
          "type": "string",
          "description": "ID da organização convidante"
        },
        "organizationName": {
          "type": "string",
          "description": "Nome descritivo da organização"
        },
        "invitedByUid": {
          "type": "string",
          "description": "UID do remetente"
        },
        "invitedByEmail": {
          "type": "string",
          "description": "E-mail do remetente"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "declined"],
          "description": "Status do convite"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Instante de envio"
        }
      },
      "required": ["id", "email", "role", "organizationId", "organizationName", "invitedByUid", "status", "createdAt"]
    }
  },
  "firestore": {
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Coleção de tarefas do sistema vinculadas por e-mail de usuário"
    },
    "users/{uid}": {
      "schema": "UserProfile",
      "description": "Perfil global de vinculação de inquilino de cada usuário"
    },
    "organizations/{orgId}": {
      "schema": "Organization",
      "description": "Metadados de organizações autônomas"
    },
    "organizations/{orgId}/members/{memberId}": {
      "schema": "Member",
      "description": "Subcoleção contendo membros listados e validados por Tenant"
    },
    "invites/{inviteId}": {
      "schema": "Invite",
      "description": "Registros de convites para controle de admissão"
    }
  }
}
