rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL SAFETY NET DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. PRIMITIVE GUIDES & VALIDATION HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check if the user is a registered member of an organization
    function isMemberOfOrg(orgId) {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // Fetch the role of the user within an organization
    function getMemberRole(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    // Verification helpers for specific privileges
    function isOrgAdmin(orgId) {
      return isMemberOfOrg(orgId) && getMemberRole(orgId) == 'admin';
    }

    function isOrgWriter(orgId) {
      return isMemberOfOrg(orgId) && (getMemberRole(orgId) == 'admin' || getMemberRole(orgId) == 'editor');
    }

    // 3. USER PROFILE MANAGEMENT
    match /users/{uid} {
      // Users can read and write their own tenancy configuration profiles
      allow get, write: if isSignedIn() && uid == request.auth.uid;
    }

    // 4. MULTI-TENANT ORGANIZATIONAL RULES
    match /organizations/{orgId} {
      // Members of the organization can view organization metadata
      allow get: if isMemberOfOrg(orgId);
      
      // Admins are authorized to update organization properties
      allow write: if isSignedIn() && (
        // Allow creating during initial bootstrapping (when org does not yet exist)
        (!exists(/databases/$(database)/documents/organizations/$(orgId)) && request.resource.data.createdBy == request.auth.uid)
        || isOrgAdmin(orgId)
      );

      // Members Subcollection inside Tenant
      match /members/{memberId} {
        // Members of the organization can list other company members
        allow read: if isMemberOfOrg(orgId);
        
        // Memberships are editable strictly inside atomic Transactions during invite accepts, 
        // or by Organization Admins
        allow write: if isSignedIn() && (
          isOrgAdmin(orgId) 
          || (memberId == request.auth.uid && !exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(memberId)))
        );
      }
    }

    // 5. INIVITATIONS COLLECTION (INVITES)
    match /invites/{inviteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isMemberOfOrg(resource.data.organizationId);
      
      // Creating invites is limited strictly to active Organization Admins
      allow create: if isSignedIn() 
        && isValidId(inviteId)
        && isOrgAdmin(request.resource.data.organizationId);

      // Updating status (like accepted) is permitted for anonymous invite acceptance transactions 
      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined')
        && (request.auth.token.email.lower() == resource.data.email.lower() || isOrgAdmin(resource.data.organizationId));

      // Deleting/revoking invitations is reserved for Org Admins or the creator
      allow delete: if isSignedIn() && (
        isOrgAdmin(resource.data.organizationId) ||
        resource.data.invitedByUid == request.auth.uid
      );
    }

    // 6. ADDTIONAL TENANT-SPECIFIC COLLECTIONS FOR DEMO / PRODUCTS
    // e.g. organizations/{orgId}/produtos/{produtoId}
    match /organizations/{orgId}/produtos/{produtoId} {
      allow read: if isMemberOfOrg(orgId);
      allow write: if isOrgWriter(orgId);
    }

    // 7. HISTORIC AUDIT LOGS (AUDIT TRAIL)
    match /audit_logs/{logId} {
      // Audit logs are strictly read-only for security officers or auditors/admins, 
      // and written solely by system backends (Cloud Functions, etc.) or admins
      allow read: if isSignedIn() 
        && isOrgAdmin(resource.data.organizationId);
      allow create: if isSignedIn() 
        && isOrgAdmin(request.resource.data.organizationId);
    }

    // 8. HISTORICAL CONSTRAINTS - COMPATIBILITY BACKUP FOR TASKS
    match /tasks/{taskId} {
      allow get: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow list: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      
      allow create: if isSignedIn() 
        && isValidId(taskId)
        && request.resource.data.userEmail == request.auth.token.email;
        
      allow update: if isSignedIn()
        && resource.data.userEmail == request.auth.token.email
        && request.resource.data.userEmail == request.auth.token.email;
        
      allow delete: if isSignedIn()
        && resource.data.userEmail == request.auth.token.email;
    }
  }
}
