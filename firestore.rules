rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test rule
    match /test/{document} {
      allow read: if true;
    }

    // Primitive Definitions & Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEmailId(email) {
      return email is string && email.size() <= 150 && email.matches('^[a-zA-Z0-9_.\\-@]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSameEmail(email1, email2) {
      return email1 is string && email2 is string && (email1 == email2 || email1.matches('(?i)^' + email2 + '$'));
    }

    // Validation Blueprint for Task Entity
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'category', 'priority', 'status', 'userEmail'])
        && data.id is string
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 20
        && data.category is string && (data.category == 'Agendamento' || data.category == 'Curinga' || data.category == 'Disponível' || data.category == 'Notas')
        && data.priority is string && (data.priority == 'Alta' || data.priority == 'Média' || data.priority == 'Baixa')
        && data.status is string && (data.status == 'Pendente' || data.status == 'Em Progresso' || data.status == 'Concluída')
        && data.userEmail is string && data.userEmail.size() <= 100
        && (!('adminEmail' in data) || (data.adminEmail is string && data.adminEmail.size() <= 150))
        && (!('description' in data) || (data.description is string && data.description.size() <= 2000))
        && (!('estimatedMinutes' in data) || data.estimatedMinutes is number)
        && (!('actualMinutes' in data) || data.actualMinutes is number)
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('googleEventId' in data) || (data.googleEventId is string && data.googleEventId.size() <= 256))
        && (!('googleEventLink' in data) || (data.googleEventLink is string && data.googleEventLink.size() <= 1024))
        && (!('googleMeetLink' in data) || (data.googleMeetLink is string && data.googleMeetLink.size() <= 1024))
        && (!('rsvpStatus' in data) || (data.rsvpStatus is string && (data.rsvpStatus == 'accepted' || data.rsvpStatus == 'declined' || data.rsvpStatus == 'tentative' || data.rsvpStatus == 'needsAction')))
        && (!('email' in data) || (data.email is string && data.email.size() <= 150))
        && (!('time' in data) || (data.time is string && data.time.size() <= 10))
        && (!('notificationLeadTime' in data) || data.notificationLeadTime is number)
        && (!('notificationSent' in data) || data.notificationSent is bool);
    }

    // Validation Blueprint for UserProfile Entity
    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'adminEmail', 'createdAt'])
        && (
          data.keys().size() == 5 
          || (data.keys().size() == 6 && ('password' in data || 'dailyReportConfig' in data))
          || (data.keys().size() == 7 && 'password' in data && 'dailyReportConfig' in data)
        )
        && data.email is string && data.email.size() <= 150
        && data.name is string && data.name.size() <= 150
        && data.role is string && (data.role == 'admin' || data.role == 'member')
        && data.adminEmail is string && data.adminEmail.size() <= 150
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!('password' in data) || (data.password is string && data.password.size() <= 100))
        && (!('dailyReportConfig' in data) || (
             data.dailyReportConfig is map 
             && data.dailyReportConfig.keys().hasAll(['enabled', 'email'])
             && data.dailyReportConfig.enabled is bool
             && data.dailyReportConfig.email is string
             && (!('sendTime' in data.dailyReportConfig) || data.dailyReportConfig.sendTime is string)
             && (!('lastSentDate' in data.dailyReportConfig) || data.dailyReportConfig.lastSentDate is string)
           ));
    }

    // Task collection
    match /tasks/{taskId} {
      allow get, list: if isSignedIn() 
        && (
          isSameEmail(resource.data.userEmail, request.auth.token.email)
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && 'adminEmail' in resource.data
            && isSameEmail(resource.data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
          )
        );
      
      allow create: if isSignedIn() 
        && isValidId(taskId)
        && isValidTask(request.resource.data)
        && (
          isSameEmail(request.resource.data.userEmail, request.auth.token.email)
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && 'adminEmail' in request.resource.data
            && isSameEmail(request.resource.data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
          )
        );
        
      allow update: if isSignedIn()
        && isValidTask(request.resource.data)
        && (
          (
            isSameEmail(resource.data.userEmail, request.auth.token.email)
            && isSameEmail(request.resource.data.userEmail, request.auth.token.email)
          )
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && 'adminEmail' in resource.data
            && 'adminEmail' in request.resource.data
            && isSameEmail(request.resource.data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
            && isSameEmail(request.resource.data.adminEmail, resource.data.adminEmail)
          )
        );
        
      allow delete: if isSignedIn()
        && (
          isSameEmail(resource.data.userEmail, request.auth.token.email)
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && 'adminEmail' in resource.data
            && isSameEmail(resource.data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
          )
        );
    }

    // User profiles collection
    match /user_profiles/{email} {
      allow get: if isSignedIn()
        && (
          isSameEmail(email, request.auth.token.email)
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && exists(/databases/$(database)/documents/user_profiles/$(email))
            && isSameEmail(get(/databases/$(database)/documents/user_profiles/$(email)).data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
          )
        );

      allow list: if isSignedIn()
        && (
          isSameEmail(email, request.auth.token.email)
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && isSameEmail(resource.data.adminEmail, get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.adminEmail)
          )
        );

      allow create: if isSignedIn()
        && isValidEmailId(email)
        && isValidUserProfile(request.resource.data)
        && (
          // Creating own profile as admin
          (isSameEmail(email, request.auth.token.email) && request.resource.data.role == 'admin')
          // Or registered as member by group's admin
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.role == 'admin'
            && request.resource.data.role == 'member'
            && isSameEmail(request.resource.data.adminEmail, request.auth.token.email)
          )
        );

      allow update: if isSignedIn()
        && isValidUserProfile(request.resource.data)
        && (
          // Personal update (e.g. password or name change)
          (isSameEmail(email, request.auth.token.email) && request.resource.data.role == resource.data.role && isSameEmail(request.resource.data.adminEmail, resource.data.adminEmail))
          // Or updated by admin
          || (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.role == 'admin'
            && isSameEmail(resource.data.adminEmail, request.auth.token.email)
            && request.resource.data.role == resource.data.role
            && isSameEmail(request.resource.data.adminEmail, resource.data.adminEmail)
          )
        );

      allow delete: if isSignedIn()
        && (
          // Admin deleting a member of their team
          (
            exists(/databases/$(database)/documents/user_profiles/$(request.auth.token.email))
            && get(/databases/$(database)/documents/user_profiles/$(request.auth.token.email)).data.role == 'admin'
            && isSameEmail(resource.data.adminEmail, request.auth.token.email)
            && !isSameEmail(email, request.auth.token.email)
          )
        );
    }
  }
}
